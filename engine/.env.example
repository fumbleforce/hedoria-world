# Copy this file to `.env.local` and fill in your key. `.env.local` is gitignored.
#
# Get a free Gemini API key at https://aistudio.google.com/apikey
#
# Vite exposes any variable prefixed with `VITE_` to the browser bundle. That
# means in dev / preview builds your key is reachable by the running page —
# fine for a personal hobby/dev setup, but DO NOT publish a build to the public
# internet with this key embedded. For a hosted deployment, run a small server
# proxy that holds the key and remove the VITE_ prefix.

# Used by the engine runtime (text generation, scene narration, dialogue,
# tile-grid filler, tile-image generation).
VITE_GEMINI_API_KEY=

# Optional model defaults (used when nothing is stored under
# engine.geminiTextModel / engine.geminiImageModel in localStorage).
# The HUD "Text" / "Image" dropdowns persist your choice and override these
# after the first selection.
#
# Text default: gemini-2.5-flash-lite. Chosen because it has the most generous
# free-tier quota among production-stable Gemini text models, and tile filling
# / NPC dialogue do not need frontier reasoning.
# Upgrade options (tighter quota, deeper reasoning):
#   - gemini-2.5-flash         (more capable, still flash-tier)
#   - gemini-3-flash-preview   (frontier flash; ~250 RPD free tier)
#   - gemini-3.1-flash         (newer flash; preview)
#   - gemini-3.1-pro-preview   (flagship; even tighter quota)
#   - gemini-2.5-pro           (larger context, slower)
# VITE_GEMINI_TEXT_MODEL=gemini-2.5-flash-lite
#
# Image default: gemini-3.1-flash-image-preview (Nano Banana 2). Alternatives:
#   - gemini-3-pro-image-preview        (Nano Banana Pro; studio quality)
#   - gemini-2.5-flash-image-preview    (older, more quota)
# VITE_GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# --- OpenRouter (optional; text and/or image via Settings → backend)
#
# The key is read only by the Vite dev server proxy (not exposed as VITE_*).
# Requires `npm run dev` — static preview/production builds have no proxy unless
# you add your own same-origin forwarder to https://openrouter.ai/api/v1/...
#
# Get a key at https://openrouter.ai/
OPENROUTER_API_KEY=
#
# Optional: OpenRouter app attribution (https://openrouter.ai/docs)
# OPENROUTER_HTTP_REFERER=https://yoursite.example
# OPENROUTER_APP_TITLE=Hedoria Engine
#
# The engine never calls api.openai.com directly; OpenRouter-only integration.
#
# In Settings you can pick `openrouter/auto` (Auto Router) so OpenRouter chooses
# a text model per request — see https://openrouter.ai/docs/guides/routing/routers/auto-router
#
# OpenRouter text calls abort after 180s by default (scene-classify can be large).
# VITE_OPENROUTER_TEXT_TIMEOUT_MS=240000
#
# OpenRouter image calls abort after 240s by default (gpt-5-image-mini, flux,
# and similar regularly take 60-180s for a single render). When the browser
# aborts, the dev-server proxy now forwards the cancel to OpenRouter so a
# stalled render does not keep running. Falls back to VITE_GEMINI_IMAGE_TIMEOUT_MS
# for backwards compatibility.
# VITE_OPENROUTER_IMAGE_TIMEOUT_MS=300000
